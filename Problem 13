inventory={'laptop':[1000,5],'mouse':[25,10]}
product_name=input("enter product:")
quantity=int(input("enter quantity:"))
  
if product_name in inventory:
    price,stock=inventory[product_name]
    if stock >= quantity:
        print("checking stock...")
        total_cost=price*quantity

discount_rate=0
if total_cost > 1000:
    discount_rate=0.15
elif total_cost > 500:
    discount_rate=0.10
    final_price=total_cost*(1-discount_rate)
    
    inventory[product_name][1]-=quantity

    print("success! total price after{discount_rate*100}%discount:**${final_price:.2f}**")
    print("updated inventory:{inventory}")
else:
    print("error:insufficient stack for {product_name}")
    print("error:product{product_name}not found")
